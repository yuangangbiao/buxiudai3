# 测试用 .env - 让 5002 能在没有真 MySQL 时启动（mock storage）
# [测试环境 - 2026-06-14]

# MySQL 配置（实际不会连接，mock storage 接管）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=steel_belt

CONTAINER_MYSQL_DATABASE=container_center
CONTAINER_MYSQL_HOST=127.0.0.1
CONTAINER_MYSQL_PORT=3306
CONTAINER_MYSQL_USER=root
CONTAINER_MYSQL_PASSWORD=

# 鉴权（[J1 修复] 强制配置）
API_KEY=test-api-key-12345
MIRROR_SHARED_SECRET=test-mirror-secret-67890
TRUSTED_PROXY=0
DB_CONNECT_TIMEOUT=2

# URL
CONTAINER_CENTER_URL=http://127.0.0.1:5002
DISPATCH_CENTER_URL=http://127.0.0.1:5003
SYNC_BRIDGE_URL=http://127.0.0.1:8008

# 时区
APP_TIMEZONE=Asia/Shanghai
APP_UTC_OFFSET=8

# 关闭非必要功能
ALERT_ENABLED=false
ENABLE_API_V1=false
ENABLE_THREAD_MANAGEMENT=false
ENABLE_CACHE_WARMUP=false

