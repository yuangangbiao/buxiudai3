# 企业微信群机器人配置
# 请复制此文件为 .env 并填入实际值

# 企业微信群机器人Webhook地址
# 获取方式：企业微信PC版 → 群设置 → 群机器人 → 添加机器人 → 复制Webhook地址
WECHAT_WORK_BOT_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# API服务器配置
API_HOST=0.0.0.0
API_PORT=5001

# 语音识别配置（可选）
# 百度语音识别 API
BAIDU_API_KEY=your_baidu_api_key
BAIDU_SECRET_KEY=your_baidu_secret_key

# 微信语音识别配置
# 使用企业微信自带的语音识别，不需要额外配置
