MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=steel_belt

CONTAINER_MYSQL_USER=root
CONTAINER_MYSQL_PASSWORD=your_password_here
