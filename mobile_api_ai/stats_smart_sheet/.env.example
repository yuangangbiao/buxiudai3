## 云端 5004 配置
CLOUD_5004_HOST=your_cloud_host
CLOUD_5004_PORT=5004
CLOUD_5004_API_KEY=your_5004_api_key_here
STATS_FORWARD_TIMEOUT=60

## 企业微信智能表格
WECHAT_SMARTSHEET_KEY=your_smart_sheet_webhook_key_here

## 库存阈值
INVENTORY_SAFETY_THRESHOLD=10
INVENTORY_SLOW_MOVING_DAYS=90

## 推送重试
STATS_MAX_RETRIES=3
STATS_RETRY_INTERVAL=2
STATS_REQUEST_TIMEOUT=30
"""
