# ============================================================
# 环境变量示例 - Docker部署
# 复制此文件为 .env 并填入实际值
# ============================================================

# MySQL数据库
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_PASSWORD=your_password_here

# JWT认证（必须，32字节以上随机密钥）
JWT_SECRET_KEY=your-very-long-random-secret-key-here-minimum-32-chars

# CORS跨域（逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Flask配置
FLASK_DEBUG=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# 微信企业号（可选）
WECHAT_WORK_CORP_ID=
WECHAT_WORK_AGENT_ID=
WECHAT_WORK_TOKEN=
WECHAT_WORK_AES_KEY=

# 微信回调安全配置
WECHAT_CLOUD_API_KEY=your-secure-api-key-here
WECHAT_ALLOWED_IPS=127.0.0.1,192.168.1.0/24
WECHAT_ALLOW_ALL_IPS=false

# 阿里云通义千问（可选）
DASHSCOPE_API_KEY=

# ============================================================
# 新增优化模块配置
# ============================================================

# API版本控制（可选，默认关闭）
ENABLE_API_V1=false

# 请求追踪中间件（可选，默认开启）
ENABLE_TRACING=true

# 线程生命周期管理（可选，默认开启）
ENABLE_THREAD_MANAGEMENT=true
SHUTDOWN_TIMEOUT=10

# 缓存预热（可选，默认关闭）
ENABLE_CACHE_WARMUP=false

# 幂等性锁超时（秒）
IDEMPOTENCY_LOCK_TIMEOUT=300

# ============================================================
# 成本核算配置（可选）
# ============================================================
# 成本告警: 低利润率阈值（低于此值触发提醒，默认10%）
# COST_LOW_MARGIN_THRESHOLD=10
# 成本告警: 高利润率阈值（高于此值触发提醒，默认50%）
# COST_HIGH_MARGIN_THRESHOLD=50

# ============================================================
# 告警配置（可选）
# ============================================================
ALERT_ENABLED=true
WECHAT_WORK_ALERT_ENABLED=false
WECHAT_WORK_ALERT_WEBHOOK=
DINGTALK_ALERT_ENABLED=false
DINGTALK_ALERT_WEBHOOK=
DINGTALK_ALERT_SECRET=
EMAIL_ALERT_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# 本地端调度中心端口
DISPATCH_PORT=5003

# ============================================================
# 云端中继服务配置 (cloud_relay)
# ============================================================
# 云端转发服务地址（本地端轮询用）
CLOUD_RELAY_URL=http://your-cloud-server:5005
# 云端轮询间隔（秒，默认1000秒≈16.6分钟）
CLOUD_POLL_INTERVAL=1000
# 云端API密钥（与云端 WECHAT_CLOUD_API_KEY 一致）
WECHAT_CLOUD_API_KEY=

# ============================================================
# cloud_relay.py 服务配置（部署在云端时使用）
# ============================================================
RELAY_HOST=0.0.0.0
RELAY_PORT=5005
RELAY_WORKERS=4
RELAY_CONN_LIMIT=100
