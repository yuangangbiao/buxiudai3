%% 不锈钢网带跟单 v3.0 最悲观架构审计 — 六维度雷达图
%% 注意：部分 Mermaid 渲染器不支持 radar 类型，以下提供 pie 替代可视化

pie title 架构评分分布 (满分100, 得分32/100)
    "已得分 32" : 32
    "扣分 68" : 68

---
%% 六维度详细分解 (可用 xychart 渲染)
xychart-beta
    title "六维度架构评分"
    x-axis ["架构内聚性", "数据一致性", "容错/可恢复性", "可维护性", "安全性", "部署可重复性"]
    y-axis "得分(满分20)" 0 --> 20
    bar [7, 4, 8, 4, 6, 3]
