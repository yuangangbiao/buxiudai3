>     @staticmethod
>     def get_kanban_stats() -> dict:
>         """获取看板统计数据（带缓存，60秒）"""
>         cache_key = "stats:orders:kanban"
>         cached_data = get_cache(cache_key)
>         if cached_data:
>             return cached_data
  
>         conn = get_connection()
>         try:
>             cursor = conn.cursor()
  
>             stats = {}
  
>             cursor.execute("""
>                 SELECT status, COUNT(*) as cnt
>                 FROM orders
>                 WHERE COALESCE(is_archived, 0) = 0
>                 GROUP BY status
>             """)
>             for row in cursor.fetchall():
