# ============================================================
# [v3.6] .gitignore - 不上传到 GitHub
# ============================================================

# ───── 归档目录（v3.6 清理的 426 个文件）─────
archive/

# ───── Python 缓存 ─────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# ───── 虚拟环境 ─────
.venv/
venv/
env/
ENV/

# ───── IDE 配置 ─────
.vscode/
.idea/
*.swp
*.swo
*~

# ───── OS 文件 ─────
.DS_Store
Thumbs.db
desktop.ini

# ───── 临时文件 ─────
*.log
*.tmp
*.bak
*.orig
*.old
*.pid
*.seed
*.pid.lock
nul  # Windows 保留字

# ───── 敏感信息 ─────
.env
.env.local
*.pem
*.key
secrets/

# ───── 数据库 / 备份 ─────
*.db
*.sqlite
*.sqlite3
*.sql.bak

# ───── Node ─────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# ───── 文档生成器 ─────
node_modules/
docs_build/
public/

# ───── 测试报告 ─────
htmlcov/
.coverage
.coverage.*
coverage.xml
.pytest_cache/
.tox/
.mypy_cache/

# ───── 项目特殊（v3.6 新增）─────
.workbuddy/  # AI 助手工作区
generate_summary_docx.js
"docs/6月30日-7月2日任务总结.docx"
!docs/CHANGELOG.md  # 但保留 CHANGELOG
