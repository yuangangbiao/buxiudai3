# -*- coding: utf-8 -*-
r"""utils/validators.py 的集成测试。

真源码行为(已读 d:\yuan\不锈钢网带跟单3.0\utils\validators.py 验证):
- CommonValidators 6 个 staticmethod: required/length/range/pattern/choices/date_format
- OrderValidator.validate_create(data): 必填 customer_name/product_type,quantity>0,delivery_date YYYY-MM-DD
- OrderValidator.validate_update(data): 过滤只保留 allowed_fields
- ProcessValidator.validate_report(data): quantity>=0,qualified_rate 0-100
- InventoryValidator.validate_adjustment(data): adjustment!=0,current_quantity>=0
- FormValidator 类: add_rule + validate(必填检查 + validators 链)

按 F16 §1:不 mock 业务路径,直接 import 真模块验证。
"""
import pytest

from core.exceptions import ValidationException
from utils.validators import (
    CommonValidators,
    OrderValidator,
    ProcessValidator,
    InventoryValidator,
    FormValidator,
)


def test_required_passes_non_empty_string():
    r"""required: 非空字符串返 value。"""
    assert CommonValidators.required("张三", "customer_name") == "张三"


def test_required_raises_on_none():
    r"""required: None 抛 ValidationException,field 必填。"""
    with pytest.raises(ValidationException, match="不能为空"):
        CommonValidators.required(None, "customer_name")


def test_required_raises_on_empty_string():
    r"""required: 空字符串 抛 ValidationException。"""
    with pytest.raises(ValidationException, match="不能为空"):
        CommonValidators.required("", "customer_name")


def test_required_raises_on_whitespace_string():
    r"""required: 纯空白字符串抛(源码第 20 行 not value.strip())。"""
    with pytest.raises(ValidationException, match="不能为空"):
        CommonValidators.required("   ", "customer_name")


def test_required_field_name_in_error():
    r"""required 错误消息含 field_name。"""
    with pytest.raises(ValidationException, match="order_no不能为空"):
        CommonValidators.required(None, "order_no")


def test_length_raises_on_non_string():
    r"""length: 非字符串抛 ValidationException。"""
    with pytest.raises(ValidationException, match="必须是字符串"):
        CommonValidators.length(123, min_len=5, field_name="order_no")


def test_length_raises_when_below_min():
    r"""length: 字符串长度 < min_len 抛。"""
    with pytest.raises(ValidationException, match="长度不能少于5"):
        CommonValidators.length("abc", min_len=5, field_name="order_no")


def test_length_raises_when_above_max():
    r"""length: 字符串长度 > max_len 抛。"""
    with pytest.raises(ValidationException, match="长度不能超过5"):
        CommonValidators.length("abcdef", max_len=5, field_name="order_no")


def test_length_passes_when_within_range():
    r"""length: 字符串长度在范围内返 value。"""
    assert CommonValidators.length("abcde", min_len=5, max_len=10) == "abcde"


def test_range_raises_on_non_numeric():
    r"""range: 非数字抛(源码第 40 行 except TypeError, ValueError)。"""
    with pytest.raises(ValidationException, match="必须是数字"):
        CommonValidators.range("abc", min_val=0, field_name="quantity")


def test_range_raises_below_min():
    r"""range: 数值 < min_val 抛。"""
    with pytest.raises(ValidationException, match="不能小于0"):
        CommonValidators.range(-1, min_val=0, field_name="quantity")


def test_range_raises_above_max():
    r"""range: 数值 > max_val 抛。"""
    with pytest.raises(ValidationException, match="不能大于100"):
        CommonValidators.range(101, max_val=100, field_name="quantity")


def test_range_returns_float_value():
    r"""range: 通过校验返 float 转换值。"""
    assert CommonValidators.range("42.5", min_val=0, max_val=100) == 42.5


def test_pattern_raises_on_mismatch():
    r"""pattern: 不匹配正则抛 ValidationException。"""
    with pytest.raises(ValidationException, match="格式不正确"):
        CommonValidators.pattern("abc123", r"^\d+$", field_name="order_no")


def test_pattern_passes_on_match():
    r"""pattern: 匹配正则返 value。"""
    assert CommonValidators.pattern("12345", r"^\d+$", field_name="order_no") == "12345"


def test_choices_raises_on_invalid():
    r"""choices: value 不在 choices 中抛。"""
    with pytest.raises(ValidationException, match="必须是以下值之一"):
        CommonValidators.choices("other", ["304", "316"], field_name="material")


def test_choices_passes_on_valid():
    r"""choices: value 在 choices 中返 value。"""
    assert CommonValidators.choices("304", ["304", "316"], field_name="material") == "304"


def test_date_format_raises_on_invalid():
    r"""date_format: 无效日期抛 ValidationException。"""
    with pytest.raises(ValidationException, match="格式应为"):
        CommonValidators.date_format("2026/01/01", "%Y-%m-%d", field_name="delivery_date")


def test_date_format_passes_on_valid():
    r"""date_format: 有效日期返 value。"""
    assert CommonValidators.date_format("2026-06-12", "%Y-%m-%d") == "2026-06-12"


def test_order_validator_create_minimal_valid():
    r"""validate_create: customer_name + product_type 完整即可。"""
    data = {"customer_name": "张三", "product_type": "乙字形网带"}
    assert OrderValidator.validate_create(data) == data


def test_order_validator_create_missing_customer():
    r"""validate_create: 缺 customer_name 抛 ValidationException(多重错误一次抛出)。"""
    with pytest.raises(ValidationException) as exc_info:
        OrderValidator.validate_create({"product_type": "乙字形网带"})
    assert "缺少必填字段: customer_name" in str(exc_info.value)


def test_order_validator_create_missing_product_type():
    r"""validate_create: 缺 product_type 抛。"""
    with pytest.raises(ValidationException) as exc_info:
        OrderValidator.validate_create({"customer_name": "张三"})
    assert "缺少必填字段: product_type" in str(exc_info.value)


def test_order_validator_create_zero_quantity_skipped():
    r"""validate_create: quantity=0 被 `if not data.get('quantity')` 当 falsy 跳过校验
    (源码第 89 行)。这是源码行为(可能为 bug),测试如实记录。
    """
    data = {
        "customer_name": "张三", "product_type": "乙字形网带", "quantity": 0,
    }
    assert OrderValidator.validate_create(data) == data


def test_order_validator_create_negative_quantity():
    r"""validate_create: quantity < 0 抛(源码第 92 行 qty <= 0)。"""
    with pytest.raises(ValidationException) as exc_info:
        OrderValidator.validate_create({
            "customer_name": "张三", "product_type": "乙字形网带", "quantity": -5,
        })
    assert "数量必须大于0" in str(exc_info.value)


def test_order_validator_create_invalid_quantity_string():
    r"""validate_create: quantity 非数字抛。"""
    with pytest.raises(ValidationException) as exc_info:
        OrderValidator.validate_create({
            "customer_name": "张三", "product_type": "乙字形网带", "quantity": "abc",
        })
    assert "数量必须是数字" in str(exc_info.value)


def test_order_validator_create_invalid_delivery_date():
    r"""validate_create: delivery_date 格式错抛。"""
    with pytest.raises(ValidationException) as exc_info:
        OrderValidator.validate_create({
            "customer_name": "张三", "product_type": "乙字形网带", "delivery_date": "2026/06/12",
        })
    assert "交货日期格式应为" in str(exc_info.value)


def test_order_validator_create_valid_with_quantity_and_date():
    r"""validate_create: 完整数据通过校验。"""
    data = {
        "customer_name": "张三", "product_type": "乙字形网带",
        "quantity": 100, "delivery_date": "2026-06-12",
    }
    assert OrderValidator.validate_create(data) == data


def test_order_validator_update_filters_unknown_fields():
    r"""validate_update: 过滤掉不在 allowed_fields 的字段(源码第 119 行)。"""
    data = {
        "customer_name": "张三", "product_type": "乙字形网带",
        "evil_field": "xss_attempt",
    }
    result = OrderValidator.validate_update(data)
    assert "evil_field" not in result
    assert result["customer_name"] == "张三"


def test_order_validator_update_returns_empty_for_no_known_fields():
    r"""validate_update: 没 allowed_fields 时返空 dict。"""
    data = {"a": 1, "b": 2}
    assert OrderValidator.validate_update(data) == {}


def test_process_validator_report_negative_quantity():
    r"""validate_report: quantity < 0 抛(源码第 136 行)。"""
    with pytest.raises(ValidationException, match="报工数量不能为负数"):
        ProcessValidator.validate_report({"quantity": -5})


def test_process_validator_report_valid_quantity():
    r"""validate_report: quantity >= 0 通过。"""
    assert ProcessValidator.validate_report({"quantity": 50}) == {"quantity": 50}


def test_process_validator_report_qualified_rate_out_of_range():
    r"""validate_report: qualified_rate 越界(0-100)抛。"""
    with pytest.raises(ValidationException, match="合格率必须在0-100之间"):
        ProcessValidator.validate_report({"qualified_rate": 150})


def test_process_validator_report_qualified_rate_valid():
    r"""validate_report: qualified_rate 在 0-100 通过。"""
    data = {"quantity": 10, "qualified_rate": 99.5}
    assert ProcessValidator.validate_report(data) == data


def test_inventory_validator_adjustment_zero():
    r"""validate_adjustment: adjustment == 0 抛(源码第 168 行)。"""
    with pytest.raises(ValidationException, match="调整数量不能为0"):
        InventoryValidator.validate_adjustment({"adjustment": 0})


def test_inventory_validator_adjustment_positive():
    r"""validate_adjustment: adjustment != 0 通过。"""
    data = {"adjustment": 10, "current_quantity": 100}
    assert InventoryValidator.validate_adjustment(data) == data


def test_inventory_validator_current_quantity_negative():
    r"""validate_adjustment: current_quantity < 0 抛。"""
    with pytest.raises(ValidationException, match="库存数量不能为负数"):
        InventoryValidator.validate_adjustment({"current_quantity": -1})


def test_form_validator_required_missing():
    r"""FormValidator.validate: required=True 且 value=None 抛。"""
    validator = FormValidator()
    validator.add_rule("order_no", required=True)
    with pytest.raises(ValidationException, match="order_no不能为空"):
        validator.validate({})


def test_form_validator_required_passes():
    r"""FormValidator.validate: required=True 且 value 非空 通过。"""
    validator = FormValidator()
    validator.add_rule("order_no", required=True)
    assert validator.validate({"order_no": "GO-001"}) == {"order_no": "GO-001"}


def test_form_validator_multiple_validators_chain():
    r"""FormValidator.validate: 多个 validators 链式调用,都通过返 validated dict。"""
    validator = FormValidator()
    validator.add_rule(
        "order_no",
        lambda v: CommonValidators.length(v, min_len=5, field_name="order_no"),
        lambda v: CommonValidators.pattern(v, r"^[A-Z0-9-]+$", field_name="order_no"),
        required=True,
    )
    result = validator.validate({"order_no": "GO-001"})
    assert result == {"order_no": "GO-001"}


def test_form_validator_collects_multiple_errors():
    r"""FormValidator.validate: 多个 validator 失败时,errors 累积后一次抛。"""
    validator = FormValidator()
    validator.add_rule(
        "name",
        lambda v: CommonValidators.length(v, min_len=5, field_name="name"),
        required=True,
    )
    validator.add_rule(
        "code",
        lambda v: CommonValidators.pattern(v, r"^\d+$", field_name="code"),
    )
    with pytest.raises(ValidationException) as exc_info:
        validator.validate({"name": "ab", "code": "abc"})
    err = str(exc_info.value)
    assert "name" in err
    assert "code" in err
