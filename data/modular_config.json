{
    "auto_publish": {
        "enabled": false,
        "retry_count": 3,
        "retry_interval": 1,
        "auto_sync_after_publish": false
    },
    "material_publish": {
        "enabled": true,
        "auto_sync": false,
        "default_priority": "normal"
    },
    "container": {
        "db_path": "mobile_api_ai/wechat_container.db",
        "api_url": "",
        "sync_interval": 60,
        "task_expiry_hours": 24
    },
    "circuit_breaker": {
        "enabled": true,
        "failure_threshold": 50,
        "success_threshold": 3,
        "failure_rate_threshold": 0.01,
        "open_timeout": 30.0,
        "recovery_timeout": 60.0
    },
    "queue": {
        "max_size": 1000,
        "retry_count": 3,
        "retry_delay": 5
    },
    "logging": {
        "level": "INFO",
        "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
    },
    "manual_publish": {
        "current_mode": "manual"
    }
}