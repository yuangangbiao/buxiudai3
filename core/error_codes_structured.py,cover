> """结构化错误码定义"""
  
  
> class ErrorCode:
>     """结构化错误码数据类。
  
>     Attributes:
>         code: 错误码字符串，如 "E1001"
>         message: 中文错误描述
>         domain: 错误域，使用 ErrorDomain 枚举值
>         severity: 严重程度，使用 ErrorSeverity 枚举值
>         http_status: 对应的 HTTP 状态码，默认 500
>     """
  
>     def __init__(self, code: str, message: str, domain: str, severity: str, http_status: int = 500):
>         self.code = code
>         self.message = message
>         self.domain = domain
>         self.severity = severity
>         self.http_status = http_status
  
-     def __repr__(self) -> str:
-         return f"ErrorCode(code={self.code!r}, message={self.message!r}, domain={self.domain!r}, severity={self.severity!r}, http_status={self.http_status})"
  
>     def __eq__(self, other: object) -> bool:
>         if not isinstance(other, ErrorCode):
>             return NotImplemented
>         return self.code == other.code
  
  
> class ErrorDomain:
>     """错误域常量——按业务模块分类错误来源。"""
>     ORDER: str = "order"
>     PRODUCTION: str = "production"
>     QUALITY: str = "quality"
>     INVENTORY: str = "inventory"
>     SYSTEM: str = "system"
>     AUTH: str = "auth"
  
  
> class ErrorSeverity:
>     """错误严重程度常量。"""
>     CRITICAL: str = "critical"
>     ERROR: str = "error"
>     WARNING: str = "warning"
  
  
