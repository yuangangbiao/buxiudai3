> def recognize_error_code(error_msg: str) -> Optional[str]:
>     """
>     从错误信息中识别错误编码
  
>     Args:
>         error_msg: 原始错误信息
  
>     Returns:
>         错误编码，如 "ERR-SYS-001"，未识别返回 None
>     """
>     if not error_msg:
>         return None
  
>     for pattern, code in ERROR_PATTERNS:
>         if re.search(pattern, error_msg, re.IGNORECASE | re.DOTALL):
>             return code
  
>     return None
  
  
