>         super().__init__('STATE_ERROR', message, details)
  
  
> class DatabaseException(BusinessException):
>     """数据库操作异常"""
      
>     def __init__(self, message: str, sql: str = None, details: Optional[dict] = None):
>         self.sql = sql
>         super().__init__('DATABASE_ERROR', message, details)
  
  
