>             "message": self.message,
>             "domain": self.domain,
>             "severity": self.severity,
>             "http_status": self.http_status,
>         }
  
  
> class ErrorDomain:
>     """错误领域分类"""
>     ORDER = "order"           # 订单领域
>     PRODUCTION = "production"  # 生产领域
>     QUALITY = "quality"        # 质量领域
>     INVENTORY = "inventory"    # 库存领域
>     SYSTEM = "system"          # 系统级
>     AUTH = "auth"              # 认证与安全
  
  
> class ErrorSeverity:
>     """错误严重级别"""
>     CRITICAL = "critical"   # 系统级故障，需立即处理
>     ERROR = "error"          # 业务错误，可重试或人工介入
>     WARNING = "warning"      # 可恢复的警告
  
  
