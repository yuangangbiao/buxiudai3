> def get_error(code_key: str) -> Optional[StructuredErrorCode]:
>     """根据错误键获取结构化错误码"""
>     return ERRORS.get(code_key)
  
  
> def get_error_by_e_code(e_code: str) -> Optional[StructuredErrorCode]:
>     """根据 E 编号（如 E0101）查找结构化错误码"""
>     for err in ERRORS.values():
>         if err.code == e_code:
>             return err
>     return None
  
  
> def get_errors_by_domain(domain: str) -> List[StructuredErrorCode]:
>     """获取指定领域的所有错误码"""
>     return [e for e in ERRORS.values() if e.domain == domain]
  
  
> def get_errors_by_severity_new(severity: str) -> List[StructuredErrorCode]:
>     """获取指定严重级别的所有错误码"""
>     return [e for e in ERRORS.values() if e.severity == severity]
  
  
> def get_all_errors() -> Dict[str, StructuredErrorCode]:
>     """获取所有结构化错误码"""
>     return ERRORS
  
  
> def get_error_count() -> int:
>     """返回结构化错误码总数"""
>     return len(ERRORS)
  
  
> def get_errors_summary() -> dict:
>     """获取结构化错误码体系摘要，按领域和严重级别统计"""
>     summary: Dict[str, Dict[str, int]] = {}
>     for err in ERRORS.values():
>         summary.setdefault(err.domain, {}).setdefault(err.severity, 0)
>         summary[err.domain][err.severity] += 1
>     return summary
  
  
