> def get_error_info(code: str) -> Optional[ErrorCode]:
>     """根据错误编码获取错误信息"""
>     return ERROR_CODES.get(code)
  
  
> def get_all_error_codes() -> List[str]:
>     """获取所有错误编码列表"""
>     return list(ERROR_CODES.keys())
  
  
> def get_errors_by_severity(severity: str) -> List[ErrorCode]:
>     """获取指定严重程度的所有错误"""
>     return [e for e in ERROR_CODES.values() if e.severity == severity]
  
  
> def format_error_for_display(code: str, original_error: str = None) -> str:
>     """格式化错误信息用于显示给用户"""
>     error_info = get_error_info(code)
>     if not error_info:
>         return f"未知错误编码: {code}\n原始错误: {original_error}"
  
>     msg_lines = [
>         f"错误编码: {code}",
>         f"错误名称: {error_info.name}",
>         f"严重程度: {error_info.severity}",
>         "",
>         "【错误描述】",
>         error_info.message,
>         "",
>         "【原因分析】",
>         error_info.cause,
>         "",
>         "【解决方案】",
>         error_info.solution,
>     ]
  
>     if error_info.example:
>         msg_lines.extend([
>             "",
>             "【错误示例】",
>             error_info.example
>         ])
  
>     msg_lines.extend([
>         "",
>         "【查看详细文档】代码审查报告/错误代码分类目录.md"
>     ])
  
>     max_len = max(len(line) for line in msg_lines)
>     separator = "=" * min(max_len, 60)
  
>     result = f"\n{separator}\n"
>     for line in msg_lines:
>         result += line + "\n"
>     result += separator + "\n"
  
>     return result
  
  
> def get_error_summary() -> str:
>     """获取错误编码体系摘要"""
>     summary = "错误编码体系摘要\n"
>     summary += "=" * 40 + "\n\n"
  
>     categories = {
>         "CRITICAL": [],
>         "HIGH": [],
>         "MEDIUM": []
>     }
  
>     for code, error in ERROR_CODES.items():
>         if error.severity in categories:
>             categories[error.severity].append(f"  {code}: {error.name}")
  
>     summary += "[CRITICAL] 严重错误:\n"
>     summary += "\n".join(categories["CRITICAL"]) + "\n\n"
  
>     summary += "[HIGH] 高风险错误:\n"
>     summary += "\n".join(categories["HIGH"]) + "\n\n"
  
>     summary += "[MEDIUM] 中等风险错误:\n"
>     summary += "\n".join(categories["MEDIUM"]) + "\n"
  
>     return summary
  
  
