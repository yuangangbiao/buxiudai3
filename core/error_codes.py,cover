-         return (
-             f"ErrorCode(code={self.code!r}, domain={self.domain!r}, "
-             f"severity={self.severity!r}, http_status={self.http_status})"
-         )
  
>     def to_dict(self) -> dict:
>         """转换为字典"""
>         return {
