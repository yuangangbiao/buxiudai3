>     """统一错误码（轻量级，用于业务层）
  
>     Attributes:
>         code: 错误码编号（如 E1001）
>         message: 人类可读的错误描述
>         domain: 错误领域（ErrorDomain 常量）
>         severity: 严重级别（ErrorSeverity 常量）
>         http_status: 对应的 HTTP 状态码
>     """
  
>     def __init__(self, code: str, message: str, domain: str, severity: str, http_status: int = 500):
